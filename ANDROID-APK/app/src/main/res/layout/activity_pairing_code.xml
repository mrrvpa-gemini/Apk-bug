<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_gradient" android:padding="24dp">
    <TextView android:id="@+id/tvTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-black" android:text="@string/your_pairing_code" android:textColor="@color/neon_cyan" android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <com.google.android.material.card.MaterialCardView android:id="@+id/cardCode" style="@style/MantaXCard" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="32dp" app:cardBackgroundColor="@color/bg_input" app:layout_constraintTop_toBottomOf="@id/tvTitle">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="32dp">
            <TextView android:id="@+id/tvPairingCode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="monospace"
                android:letterSpacing="0.2" android:text="XXXX-XXXX" android:textColor="@color/neon_green" android:textSize="42sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvExpires" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                android:text="Berakhir dalam 5:00" android:textColor="@color/warning" android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.button.MaterialButton android:id="@+id/btnCopy" style="@style/MantaXButton" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="24dp" android:text="@string/copy_clipboard" app:icon="@drawable/ic_copy" app:iconGravity="textStart" app:layout_constraintTop_toBottomOf="@id/cardCode" />
    <ImageView android:id="@+id/ivQRDisplay" android:layout_width="200dp" android:layout_height="200dp" android:layout_marginTop="24dp" android:background="@color/bg_input"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/btnCopy" />
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"
        android:text="Menunggu scan…" android:textColor="@color/text_secondary" android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/ivQRDisplay" />
</androidx.constraintlayout.widget.ConstraintLayout>