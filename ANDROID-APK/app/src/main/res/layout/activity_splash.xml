<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg_dark">
    <View android:id="@+id/glowCircle" android:layout_width="200dp" android:layout_height="200dp" android:background="@drawable/bg_neon_glow"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintVertical_bias="0.4" />
    <ImageView android:id="@+id/ivLogo" android:layout_width="100dp" android:layout_height="100dp" android:src="@drawable/ic_whatsapp" android:tint="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="@id/glowCircle" app:layout_constraintEnd_toEndOf="@id/glowCircle" app:layout_constraintStart_toStartOf="@id/glowCircle" app:layout_constraintTop_toTopOf="@id/glowCircle" />
    <TextView android:id="@+id/tvAppName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:fontFamily="sans-serif-black"
        android:text="Manta'X" android:textColor="@color/neon_cyan" android:textSize="36sp" android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/glowCircle" />
    <TextView android:id="@+id/tvTagline" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="sans-serif-medium"
        android:text="@string/app_tagline" android:textColor="@color/colorAccent" android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvAppName" />
    <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="200dp" android:layout_height="4dp" android:layout_marginTop="32dp"
        android:indeterminate="true" android:indeterminateTint="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvTagline" />
    <TextView android:id="@+id/tvVersion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="24dp"
        android:text="v1.0.0-GACOR" android:textColor="@color/text_disabled" android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>